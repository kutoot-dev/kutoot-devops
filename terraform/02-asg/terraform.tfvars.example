# Copy to terraform.tfvars: cp terraform.tfvars.example terraform.tfvars
# Full IaC: Run 00-mysql first, then use_mysql_module=true (auto-set by quick-recreate.ps1)
# Existing MySQL: Set use_mysql_module=false, mysql_security_group_id, db_host

aws_region   = "ap-south-1"
project_name = "kutoot"
environment  = "prod"

key_name = "kutoot-sql"
allowed_ssh_cidr = "101.0.63.108/32"

# When use_mysql_module=true: get from 00-mysql (run quick-recreate.ps1)
# When use_mysql_module=false: set manually
use_mysql_module      = false
mysql_security_group_id = "sg-xxxxxxxxx"
db_host               = "172.31.45.181"

asg_min_size         = 1
asg_max_size         = 8
asg_desired_capacity = 1

# --- User Data (auto-deploys Laravel on new instances) ---
db_database = "kutoot_backend"
db_username  = "kutoot_app"
# Set here OR use DB_PASSWORD GitHub secret (leave empty to use secret + S3 .env)
db_password = "YOUR_MYSQL_PASSWORD"

laravel_repo_url = "https://github.com/kutoot-dev/kutoot.git"
