###############################################
# KUTOOT ENVIRONMENT TEMPLATE
# Copy to .env on server and fill in values
# NEVER commit .env with real secrets
###############################################

APP_NAME=Kutoot
APP_ENV=production
APP_KEY=base64:CHANGE_ME_RUN_php_artisan_key_generate
APP_DEBUG=false
APP_URL=https://www.kutoot.com
APP_TIMEZONE="Asia/Kolkata"

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=172.31.45.181
DB_PORT=3306
DB_DATABASE=kutoot_backend
DB_USERNAME=admin
DB_PASSWORD=CHANGE_ME

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
QUEUE_CONNECTION=sync

CACHE_STORE=file
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="it@kutoot.com"
MAIL_FROM_NAME="Kutoot"

# AWS S3
AWS_BUCKET=kutoot-backend
AWS_DEFAULT_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_URL=https://kutoot-backend.s3.ap-south-1.amazonaws.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Logging
LOG_VIEWER_ENABLED=true
LOG_VIEWER_EMAILS=it@kutoot.com

ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_DB_CONNECTION=mysql

# NativePHP
NATIVEPHP_APP_ID=www.kutoot.com
NATIVEPHP_APP_VERSION="1.0.0"
NATIVEPHP_APP_VERSION_CODE="1"
NATIVEPHP_DEVELOPMENT_TEAM=CHANGE_ME

# Business
APP_CURRENCY=INR
PLATFORM_FEE=5
GST_RATE=18
PLATFORM_FEE_TYPE=percentage

# Razorpay
RAZORPAY_KEY_ID=CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME
PAYMENT_DEFAULT_GATEWAY=razorpay
PLAN_TAX_TYPE=exclusive

# SMS (Way2Mint)
SMS_DRIVER=way2mint
WAY2MINT_BASE_URL=https://apibulksms.way2mint.com
WAY2MINT_USERNAME=CHANGE_ME
WAY2MINT_PASSWORD=CHANGE_ME
WAY2MINT_SENDER_ID=KUTOOT
WAY2MINT_PE_ID=CHANGE_ME
WAY2MINT_OTP_TEMPLATE_ID=CHANGE_ME
WAY2MINT_PROVIDER_PE_ID=CHANGE_ME

OTP_LENGTH=6

OCTANE_SERVER=frankenphp

# Upload
MAX_UPLOAD_SIZE_MB=1024
FILESYSTEM_DISK=s3
OBJECT_STORAGE_DRIVER=s3

# Frontend
FRONTEND_URL=https://www.kutoot.com
